# ── shared pre-processing for waterfall / per-card KPIs ──────────────────────
_CREDIT = ["Insuff_Decline", "Credit_Line", "Cash_Line"]
_WFALL  = 'STIP_DECLINE|_Other declines|FALCON_DECLINE|Credit Related Decline'

def _prep_waterfall(df):
    """Return declined rows with credit types merged → 'Credit Related Decline'."""
    d = df[df['decisioning'].str.contains('declin', case=False, na=False)].copy()
    d['type'] = d['type'].mask(d['type'].isin(_CREDIT), 'Credit Related Decline')
    return d[d['type'].str.contains(_WFALL, case=False, na=False)]

