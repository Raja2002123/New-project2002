def pg_per_card(pdf, df):
    for card in CARDS:
        if df[df["cardtype"]==card].empty: continue
        pt,pu,rtt,rtu,rt,ru = kpi_per_card(df,card)
        fig, gs = page(4,2,f"{card} – Decline Breakdown")
        plot_line(rtt,f"{card} – # Decline Rate",ax=ax(fig,gs,0,0),ylim_top=5)
