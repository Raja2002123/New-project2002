def page2_decline_type(df_cat, mt):
    months = [r['month'] for _, r in mt.iterrows()]
    x = range(len(months))
    cats = ['Credit Related Decline','Falcon Decline','Other Decline','STIP Decline']
    cat_colors = [COLORS['cr_decline'], COLORS['falcon'],
                  COLORS['other'], COLORS['stip']]

    fig, axes = plt.subplots(2, 2, figsize=(20, 10))
    fig.suptitle('Decline Rate – By Decline Type & Waterfall Distribution', fontsize=11, fontweight='bold')

    for col_idx, (metric, title_sfx) in enumerate([('rate_n','#'),('rate_s','$')]):
        # ── Decline Rate line chart ──
        ax = axes[0, col_idx]
        ax.set_title(f'{metric[5:].upper()} Decline Rate – By Decline Type', fontsize=8, fontweight='bold')
        for cat, color in zip(cats, cat_colors):
            sub = df_cat[df_cat['cat'] == cat]
            vals = [sub[sub['month']==m][metric].values[0] if m in sub['month'].values else 0 for m in months]
            ax.plot(x, vals, color=color, marker='o', markersize=3, linewidth=1.2, label=cat)
            for xi, v in enumerate(vals):
                if v > 0.0001:
                    ax.text(xi, v+0.0001, f'{v*100:.2f}%', ha='center', fontsize=4, color=color)
        style_ax(ax, months, 'Rate', pct_y=True)
        ax.legend(fontsize=5, loc='upper left', ncol=2)

        # ── Waterfall stacked bar ──
        ax = axes[1, col_idx]
        ax.set_title(f'{metric[5:].upper()} Decline Waterfall Distribution', fontsize=8, fontweight='bold')
        # compute shares of total declined
        bottom = np.zeros(len(months))
        cat_order = ['Other Decline','Credit Related Decline','STIP Decline','Falcon Decline']
        cat_colors2 = [COLORS['other'], COLORS['cr_decline'], COLORS['stip'], COLORS['falcon']]
        n_col = 'n' if metric == 'rate_n' else 's'
        total_col = 'total_n' if metric == 'rate_n' else 'total_s'
        for cat, color in zip(cat_order, cat_colors2):
            sub = df_cat[df_cat['cat'] == cat]
            dec_totals = [df_cat[df_cat['month']==m][n_col].sum() for m in months]
            vals = []
            for mi, m in enumerate(months):
                s = sub[sub['month']==m]
                cv = s[n_col].values[0] if len(s) else 0
                dt = dec_totals[mi]
                vals.append(cv/dt if dt else 0)
            vals = np.array(vals)
            bars = ax.bar(x, vals, bottom=bottom, color=color, label=cat, width=0.7)
            for xi, (b, v) in enumerate(zip(bottom, vals)):
                if v > 0.03:
                    ax.text(xi, b+v/2, f'{v*100:.1f}%', ha='center', va='center', fontsize=4, color='white')
            bottom += vals
        style_ax(ax, months, 'Share of Declines', pct_y=True)
        ax.set_ylim(0, 1.05)
        ax.legend(fontsize=5, loc='lower left', ncol=2)

    fig.tight_layout(rect=[0,0,1,0.96])
    return fig_to_bytes(fig)

