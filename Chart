    doc = SimpleDocTemplate(out, pagesize=landscape(A3),
          leftMargin=0.3*inch, rightMargin=0.3*inch,
          topMargin=0.3*inch,  bottomMargin=0.3*inch)
    pw = landscape(A3)[0] - 0.6*inch
    story = []
    for i,buf in enumerate(pages):
        story.append(RLImage(buf, width=pw, height=pw*0.56))
        if i < len(pages)-1: story.append(PageBreak())
    doc.build(story)
    print(f'✅  Saved → {out}')

if __name__ == '__main__':
    main()
