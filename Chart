    return dec.div(total).mul(100).round(4)

# Per-card decline by reason
def _card_decline_reason(df, card):
    d = _declines(df)
    d = _credit_list_remap(d)
    d = _waterfall_filter(d)
    d = d[d['cardtype'] == card]
    pivot = d.groupby(['month', 'type'])['txns'].sum().unstack(fill_value=0)
    total_card = df[df['cardtype'] == card].groupby('month')['txns'].sum()
    rate = pivot.div(total_card, axis=0).mul(100).round(4)
    return rate

def _card_decline_reason_usd(df, card):
    d = _declines(df)
    d = _credit_list_remap(d)
    d = _waterfall_filter(d)
    d = d[d['cardtype'] == card]
    pivot = d.groupby(['month', 'type'])['amt_usd'].sum().unstack(fill_value=0)
    total_card = df[df['cardtype'] == card].groupby('month')['amt_usd'].sum()
    rate = pivot.div(total_card, axis=0).mul(100).round(4)
    return rate

# CP/CNP decline waterfall
def decline_cp_kpi(df):
    d = _declines(df)
    d = _credit_list_remap(d)
    d = _waterfall_filter(d)
    cp = d[d['CP_CNP'] == 'CP']
