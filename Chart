    plot_line(rtt,"# Decline Rate – CP/CNP",ax=ax(fig,gs,2,0),ylim_top=20)
    plot_line(rtu,"$ Decline Rate – CP/CNP",ax=ax(fig,gs,2,1),ylim_top=20)
