"""
charts.py  –  reusable chart helpers for AE Auth Decline dashboard
Matches the visual style of the 12-page reference PDF exactly.
"""
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import pandas as pd
import numpy as np

# ── Colour palettes ───────────────────────────────────────────────────────────
C_GRN_RED   = ['#4CAF50', '#F44336']                          # approved / declined
C_WATERFALL = ['#1976D2', '#FF5722', '#43A047', '#7B1FA2']   # CRD / Falcon / Other / STIP
C_CRD       = ['#00ACC1', '#006064', '#26C6DA']               # Insuff / Credit / Cash teal shades
C_STIP      = ['#FF9800', '#F57C00']                          # STIP / Non-STIP orange
C_CP        = ['#1565C0', '#42A5F5']                          # CP / CNP blue shades
C_CARD      = ['#1565C0','#1976D2','#4CAF50','#FF9800',
               '#9C27B0','#F44336','#00BCD4']                 # card types
C_RATE      = ['#E53935','#1E88E5','#43A047','#FB8C00',
               '#8E24AA','#00ACC1']                           # decline rate lines
LINE_RED    = '#E53935'


# ── helpers ──────────────────────────────────────────────────────────────────
def _mlbl(idx):
    """DatetimeIndex / mixed → list of 'Mon-YY' strings."""
    out = []
    for d in idx:
        try:
            out.append(pd.Timestamp(d).strftime('%b-%y'))
        except Exception:
            out.append(str(d))
    return out


def _fmtk(v):
    if abs(v) >= 1_000_000: return f'{v/1_000_000:.2f}M'
    if abs(v) >= 1_000:     return f'{v/1_000:.1f}K'
    return f'{v:.0f}'


def _drop_total(df):
    """Remove a 'Total' column if present."""
    return df[[c for c in df.columns if str(c).strip().lower() != 'total']]


def _common(ax, title, ylabel='', fontsize=8):
    ax.set_title(title, fontsize=fontsize, fontweight='bold', pad=4)
    ax.set_ylabel(ylabel, fontsize=7)
    ax.tick_params(axis='both', labelsize=6.5)
    ax.spines[['top', 'right']].set_visible(False)


def _legend(ax, ncol=5):
    ax.legend(loc='upper center', bbox_to_anchor=(0.5, -0.32),
              ncol=ncol, fontsize=6, frameon=False,
              handlelength=1.0, handleheight=0.8)


# ══════════════════════════════════════════════════════════════════════════════
#  1.  STACKED BAR  (100 % stacked, white % labels inside segments)
# ══════════════════════════════════════════════════════════════════════════════
def plot_bar(df_plot, title, ylabel='% of Transactions',
             percent=True, ax=None, colors=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(11, 5))

    df = _drop_total(df_plot.copy().fillna(0))
    months = _mlbl(df.index)
    x  = np.arange(len(months))
    cs = list(df.columns)
    pal = (colors if colors else C_GRN_RED)[:]
    while len(pal) < len(cs):
        pal += C_WATERFALL

    bottoms = np.zeros(len(x))
    for i, col in enumerate(cs):
        vals = df[col].values.astype(float)
        ax.bar(x, vals, bottom=bottoms,
               color=pal[i % len(pal)], label=col,
               width=0.65, edgecolor='white', linewidth=0.4)
        for xi, (v, bot) in enumerate(zip(vals, bottoms)):
            if v > 2.0:
                ax.text(xi, bot + v/2, f'{v:.1f}%',
                        ha='center', va='center', fontsize=5.2,
                        color='white', fontweight='bold')
        bottoms += vals

    ax.set_xticks(x)
    ax.set_xticklabels(months, rotation=45, ha='right', fontsize=6.5)
    if percent:
        ax.set_ylim(0, 108)
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, _: f'{v:.0f}%'))
    _common(ax, title, ylabel)
    _legend(ax, ncol=min(len(cs), 5))
    return ax


# ══════════════════════════════════════════════════════════════════════════════
#  2.  LINE CHART  (markers + annotated values)
# ══════════════════════════════════════════════════════════════════════════════
def plot_line(df_plot, title, ylabel='% of Transactions',
              percent=True, ax=None, colors=None, auto_ylim=True):
    if ax is None:
        _, ax = plt.subplots(figsize=(11, 5))

    df  = _drop_total(df_plot.copy().fillna(0))
    months = _mlbl(df.index)
    x   = np.arange(len(months))
    cs  = list(df.columns)
    pal = (colors if colors else C_RATE)[:]
    while len(pal) < len(cs):
        pal += C_WATERFALL

    all_vals = df.values.astype(float)
    vmax = float(all_vals.max()) if all_vals.size else 1.0
    offset = max(vmax * 0.03, 0.3)

    for i, col in enumerate(cs):
        vals = df[col].values.astype(float)
        ax.plot(x, vals, marker='o', markersize=3.5, linewidth=1.3,
                color=pal[i % len(pal)], label=col)
        for xi, v in enumerate(vals):
            ax.text(xi, v + offset, f'{v:.2f}%',
                    ha='center', va='bottom', fontsize=4.8,
                    color=pal[i % len(pal)])

    ax.set_xticks(x)
    ax.set_xticklabels(months, rotation=45, ha='right', fontsize=6.5)
    ax.margins(x=0.04)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, _: f'{v:.2f}%'))
    _common(ax, title, ylabel)
    _legend(ax, ncol=min(len(cs), 5))
    return ax


# ══════════════════════════════════════════════════════════════════════════════
#  3.  COMBO CHART  (stacked absolute bars + red dashed decline-rate line)
#      Matches top-row charts on Page 1 of the reference PDF
# ══════════════════════════════════════════════════════════════════════════════
def plot_combo(df_abs, df_pct, title,
               bar_ylabel='# Transactions', line_ylabel='% Decline Rate',
               ax=None, colors=None, declined_col=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(11, 5))

    df_b = _drop_total(df_abs.copy().fillna(0))
    months = _mlbl(df_b.index)
    x   = np.arange(len(months))
    cs  = list(df_b.columns)
    pal = (colors if colors else C_GRN_RED)[:]
    while len(pal) < len(cs):
        pal += C_WATERFALL

    # ── stacked bars (absolute counts) ───────────────────────────────────────
    bottoms = np.zeros(len(x))
    for i, col in enumerate(cs):
        vals = df_b[col].values.astype(float)
        ax.bar(x, vals, bottom=bottoms,
               color=pal[i % len(pal)], label=col,
               width=0.65, edgecolor='white', linewidth=0.3)
        for xi, (v, bot) in enumerate(zip(vals, bottoms)):
            if v > 0:
                ax.text(xi, bot + v/2, _fmtk(v),
                        ha='center', va='center', fontsize=4.5,
                        color='white', fontweight='bold')
        bottoms += vals

    ax.set_xticks(x)
    ax.set_xticklabels(months, rotation=45, ha='right', fontsize=6.5)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(
        lambda v, _: f'{v/1e6:.1f}M' if v >= 1e6 else f'{v/1e3:.0f}K'))
    ax.set_ylabel(bar_ylabel, fontsize=7)
    ax.tick_params(axis='y', labelsize=6.5)

    # ── decline-rate line (twin axis) ────────────────────────────────────────
    ax2 = ax.twinx()
    if df_pct is not None and declined_col and declined_col in df_pct.columns:
        pct = df_pct[declined_col].values.astype(float)
        ax2.plot(x, pct, color=LINE_RED, marker='o',
                 markersize=3, linewidth=1.3, linestyle='--', label='Decline Rate')
        vmax = float(pct.max()) if pct.size else 1
        for xi, v in enumerate(pct):
            ax2.text(xi, v + max(vmax*0.04, 0.1), f'{v:.1f}%',
                     ha='center', va='bottom', fontsize=4.8, color=LINE_RED)
        ax2.set_ylabel(line_ylabel, fontsize=7, color=LINE_RED)
        ax2.tick_params(axis='y', labelsize=6.5, labelcolor=LINE_RED)
        ax2.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, _: f'{v:.1f}%'))
        ax2.spines[['top']].set_visible(False)

    _common(ax, title, bar_ylabel)
    h1, l1 = ax.get_legend_handles_labels()
    if df_pct is not None and declined_col:
        h2, l2 = ax2.get_legend_handles_labels()
        h1 += h2; l1 += l2
    ax.legend(h1, l1, loc='upper center', bbox_to_anchor=(0.5, -0.32),
              ncol=min(len(h1), 5), fontsize=6, frameon=False)
    return ax, ax2


# ══════════════════════════════════════════════════════════════════════════════
#  4.  TABLE  (styled, dark header, alternating rows)
# ══════════════════════════════════════════════════════════════════════════════
def plot_table(df_plot, title, percent=False, is_abs=False, ax=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(11, 3))

    ax.axis('off')
    df = _drop_total(df_plot.copy().fillna(0))
    row_labels = _mlbl(df.index)
    col_labels  = list(df.columns)

    cell_text = []
    for _, row in df.iterrows():
        if is_abs:
            cell_text.append([_fmtk(v) for v in row])
        elif percent:
            cell_text.append([f'{v:.2f}%' for v in row])
        else:
            cell_text.append([f'{v:.2f}' for v in row])

    tbl = ax.table(cellText=cell_text,
                   rowLabels=row_labels,
                   colLabels=col_labels,
                   loc='center', cellLoc='center')
    tbl.auto_set_font_size(False)
    tbl.set_fontsize(6.5)
    tbl.scale(1.0, 1.3)

    for (r, c), cell in tbl.get_celld().items():
        cell.set_linewidth(0.4)
        if r == 0:                         # header row
            cell.set_facecolor('#2C3E50')
            cell.get_text().set_color('white')
            cell.get_text().set_fontweight('bold')
        elif c == -1:                      # row-label column
            cell.set_facecolor('#ECF0F1')
        else:
            cell.set_facecolor('#F8F9FA' if r % 2 == 0 else 'white')

    ax.set_title(title, fontsize=8, fontweight='bold', pad=6)
    return ax
