def CRD_Granular_kpi(df):
    d = df[df['decisioning'].str.contains('declin', case=False, na=False)].copy()
    d = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    return to_percentage(d.groupby(['month','type'])['txns'].sum().unstack(fill_value=0))

def CRD_Granular_kpi_usd(df):
    d = df[df['decisioning'].str.contains('declin', case=False, na=False)].copy()
    d = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    return to_percentage(d.groupby(['month','type'])['amt_usd'].sum().unstack(fill_value=0))

# ── NEW  – CRD as % of ALL transactions  (for Page-3 top line charts) ────────
def crd_pct_of_total(df, val='txns'):
    total = df.groupby('month')[val].sum()
    d = df[df['decisioning'].str.contains('declin', case=False, na=False)].copy()
    crd = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    crd_tot = crd.groupby('month')[val].sum()
    pct_total  = (crd_tot / total * 100).round(2).rename('CRD % of #' if val=='txns' else 'CRD % of $')
    dec_total  = d.groupby('month')[val].sum()
    pct_dec    = (crd_tot / dec_total.replace(0, np.nan) * 100).round(2).rename(
                    'CRD % of Decline #' if val=='txns' else 'CRD % of Decline $')
    return pd.concat([pct_total, pct_dec], axis=1).fillna(0)

# ── NEW  – CRD Granular as % of ALL transactions  (Page-3 bottom) ───────────
def crd_granular_pct_of_total(df, val='txns'):
    total = df.groupby('month')[val].sum()
    d = df[df['decisioning'].str.contains('declin', case=False, na=False)].copy()
    d = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    grp = d.groupby(['month','type'])[val].sum().unstack(fill_value=0)
    return grp.div(total, axis=0).mul(100).round(2).fillna(0)

# ── NEW  – Decline-type rate as % of ALL transactions (Page 2 top lines) ────
def decline_type_rate(df, val='txns'):
    total = df.groupby('month')[val].sum()
    d = _prep_waterfall(df)
    grp = d.groupby(['month','type'])[val].sum().unstack(fill_value=0)
    return grp.div(total, axis=0).mul(100).round(2).fillna(0)

# ── NEW  – Card-type overall decline rate  (Page 5 line) ────────────────────
def card_type_decline_rate(df, val='txns'):
    excl = ['TITANIUM','TITANIUM2','WORLD']
    f    = df[~df['cardtype'].str.upper().isin(excl)]
    tot  = f.groupby(['month','cardtype'])[val].sum().unstack(fill_value=0)
    dec  = f[f['decisioning'].str.contains('declin', case=False, na=False)]
    d    = dec.groupby(['month','cardtype'])[val].sum().unstack(fill_value=0)
    d    = d.reindex(columns=tot.columns, fill_value=0)
    return (d.div(tot.replace(0, np.nan)) * 100).round(2).fillna(0)


