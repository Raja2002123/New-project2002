#!/usr/bin/env python3
"""
Credit Card Decline Dashboard Generator
Usage: python decline_dashboard.py [your_file.xlsx]
"""

import sys, io, warnings
import numpy as np
import pandas as pd
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
from reportlab.lib.pagesizes import A3, landscape
from reportlab.platypus import SimpleDocTemplate, Image as RLImage, PageBreak
from reportlab.lib.units import inch
warnings.filterwarnings('ignore')

# ── Constants ────────────────────────────────────────────────
MONTHS = ['Jan25','Feb25','Mar25','Apr25','May25','Jun25',
          'Jul25','Aug25','Sep25','Oct25','Nov25','Dec25']

COLORS = {
    'approved': '#4CAF50', 'declined': '#F44336',
    'credit':   '#1565C0', 'falcon':   '#FF8F00',
    'other':    '#00897B', 'stip':     '#8E24AA',
    'cp':       '#7986CB', 'cnp':      '#29B6F6',
    'nonstip':  '#FF8F00',
}
CARD_COLORS = ['#E53935','#1E88E5','#FDD835','#FB8C00','#8E24AA','#F48FB1','#00BCD4','#795548']
CAT_COLORS  = [COLORS['credit'], COLORS['falcon'], COLORS['other'], COLORS['stip']]
CATS        = ['Credit Related Decline','Falcon Decline','Other Decline','STIP Decline']

# ── Load & Clean Data ────────────────────────────────────────
def load(path):
    df = pd.read_excel(path, sheet_name=0)
    df.columns = [c.strip() for c in df.columns]

    # Normalise month: "Dec-25" or "Dec25" → "Dec25"
    df['month'] = df['month'].astype(str).str.replace(r'[-\s]','',regex=True)

    df['is_approved'] = df['decisioning'].str.contains('Approved', case=False, na=False)
    df['is_declined'] = df['decisioning'].str.contains('Declined', case=False, na=False)

    def cat(row):
        t = str(row.get('tag','')).upper()
        if 'FALCON' in t: return 'Falcon Decline'
        if 'STIP'   in t: return 'STIP Decline'
        if any(k in t for k in ['INSUFF','CASH_LINE','CREDIT_LINE']): return 'Credit Related Decline'
        return 'Other Decline'

    df['cat']      = df.apply(lambda r: cat(r) if r['is_declined'] else None, axis=1)
    df['is_stip']  = df['tag'].astype(str).str.upper().str.contains('STIP', na=False)
    df['cp_cnp']   = df['CP_CNP'].astype(str).str.strip().str.upper()
    df['cardtype'] = df['cardtype'].astype(str).str.strip().str.upper()

    avail = df['month'].unique()
    global MONTHS
    MONTHS = [m for m in MONTHS if m in avail] or sorted(avail)
    return df

# ── Aggregations ─────────────────────────────────────────────
def agg_monthly(df):
    rows = []
    for m in MONTHS:
        s = df[df['month']==m]
        an = s[s['is_approved']]['txns'].sum()
        dn = s[s['is_declined']]['txns'].sum()
        as_ = s[s['is_approved']]['amt_usd'].sum()
        ds  = s[s['is_declined']]['amt_usd'].sum()
        rows.append(dict(month=m, an=an, dn=dn, tn=an+dn,
                         as_=as_, ds=ds, ts=as_+ds))
    mt = pd.DataFrame(rows)
    mt['dr_n'] = mt['dn']/mt['tn']
    mt['dr_s'] = mt['ds']/mt['ts']
    return mt

def agg_cat(df, mt):
    rows = []
    for m in MONTHS:
        s  = df[(df['month']==m) & df['is_declined']]
        tn = mt.loc[mt['month']==m,'tn'].values[0]
        ts = mt.loc[mt['month']==m,'ts'].values[0]
        for cat in CATS:
            c = s[s['cat']==cat]
            rows.append(dict(month=m, cat=cat,
                             n=c['txns'].sum(), s=c['amt_usd'].sum(),
                             tn=tn, ts=ts,
                             dn=s['txns'].sum(), ds=s['amt_usd'].sum()))
    return pd.DataFrame(rows)

# ── Chart Utilities ───────────────────────────────────────────
def fig2buf(fig):
    buf = io.BytesIO()
    fig.savefig(buf, format='png', dpi=150, bbox_inches='tight')
    plt.close(fig); buf.seek(0)
    return buf

def style(ax, ylabel='', pct=False):
    ax.set_xticks(range(len(MONTHS)))
    ax.set_xticklabels(MONTHS, fontsize=5.5, rotation=45, ha='right')
    ax.tick_params(axis='y', labelsize=5.5)
    ax.set_ylabel(ylabel, fontsize=5.5)
    if pct: ax.yaxis.set_major_formatter(mticker.PercentFormatter(xmax=100))
    ax.spines[['top','right']].set_visible(False)
    ax.grid(axis='y', alpha=0.2, lw=0.5)
    ax.set_facecolor('#F8F9FA')

def label_stacked(ax, x, bottom, vals, thr=4, fs=4):
    for xi,(b,v) in enumerate(zip(bottom,vals)):
        if v > thr:
            ax.text(xi, b+v/2, f'{v:.1f}%', ha='center', va='center',
                    fontsize=fs, color='white', fontweight='bold')

def stacked_bar(ax, x, series, colors, labels):
    bot = np.zeros(len(MONTHS))
    for vals, color, label in zip(series, colors, labels):
        vals = np.array(vals)
        ax.bar(x, vals, bottom=bot, color=color, label=label, width=0.7, zorder=3)
        label_stacked(ax, x, bot, vals)
        bot += vals

