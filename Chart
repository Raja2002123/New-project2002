            elif r % 2 == 0:
                cell.set_facecolor('#F5F5F5')

    fk = lambda v: f'{v/1000:.2f}K'
    fm = lambda v: f'${v/1e6:.2f}M'

    draw_table(axes[0],
        [[fk(mt.loc[mt['month'] == m, 'an'].values[0]) for m in MONTHS],
         [fk(mt.loc[mt['month'] == m, 'dn'].values[0]) for m in MONTHS],
         [fk(mt.loc[mt['month'] == m, 'tn'].values[0]) for m in MONTHS],
         [f"{mt.loc[mt['month'] == m, 'dr_n'].values[0]*100:.2f}%" for m in MONTHS]],
        ['Approved', 'Declined', 'Grand Total', 'Decline Rate'],
        '# Transaction Summary')

    draw_table(axes[1],
        [[fm(mt.loc[mt['month'] == m, 'as_'].values[0]) for m in MONTHS],
         [fm(mt.loc[mt['month'] == m, 'ds'].values[0]) for m in MONTHS],
         [fm(mt.loc[mt['month'] == m, 'ts'].values[0]) for m in MONTHS],
         [f"{mt.loc[mt['month'] == m, 'dr_s'].values[0]*100:.2f}%" for m in MONTHS]],
        ['Approved', 'Declined', 'Grand Total', 'Decline Rate'],
