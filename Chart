# Decline rate by card type
def decline_rate_by_cardtype(df):
    EXCL = ['TITANIUM', 'TITANIUM2', 'WORLD']
    d = df[~df['cardtype'].isin(EXCL)]
    total = d.groupby(['month', 'cardtype'])['txns'].sum().unstack(fill_value=0)
    dec = _declines(d).groupby(['month', 'cardtype'])['txns'].sum().unstack(fill_value=0)
    return dec.div(total).mul(100).round(4)

def decline_rate_by_cardtype_usd(df):
