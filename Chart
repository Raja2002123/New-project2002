"""
charts.py – Reusable chart functions that match the dashboard images exactly.

Colour rules:
  • Approved  = green  (#4CAF50)
  • Declined  = red    (#F44336)
  • Credit Related Decline = dark blue
  • Falcon Decline         = orange
  • Other Decline          = cyan/teal
  • STIP Decline           = pink/magenta
  • Stacked bars have % labels centred in each segment
  • Line charts have % labels above each data-point marker
  • Tables replicate the raw grid shown under each chart
"""

import matplotlib
matplotlib.use('Agg')   # non-interactive backend (safe for PDF generation)

import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import matplotlib.patches as mpatches
import pandas as pd
import numpy as np

# ─────────────────────────────────────────────────────────────
# COLOUR PALETTE  (matches the dashboard screenshots)
# ─────────────────────────────────────────────────────────────
_PALETTE = [
    '#1565C0',   # deep blue
    '#FF8F00',   # amber / orange
    '#00ACC1',   # cyan
    '#E91E63',   # pink / magenta
    '#558B2F',   # dark green
    '#6A1B9A',   # purple
    '#F57F17',   # gold
    '#00695C',   # dark teal
    '#BF360C',   # dark orange-red
    '#1A237E',   # indigo
]

GREEN  = '#4CAF50'
RED    = '#F44336'


def _month_labels(index):
    """Return 'Jan-25' style labels from a DatetimeIndex or plain index."""
    try:
        return [pd.Timestamp(d).strftime('%b-%y') for d in index]
    except Exception:
        return [str(d) for d in index]


def _color_list(df, colors=None):
    n = len(df.columns)
    if colors and len(colors) >= n:
        return list(colors[:n])
    return (_PALETTE * ((n // len(_PALETTE)) + 1))[:n]


# ─────────────────────────────────────────────────────────────
# STACKED BAR  (with optional % labels inside each segment)
# ─────────────────────────────────────────────────────────────
def plot_bar(df_plot, title, ylabel, colors=None, percent=True, ax=None):
    """
    Stacked bar chart.
    percent=True  → y-axis 0-100 %, labels shown as '12.34%'
    percent=False → raw values, labels formatted with K/M suffix
    """
    if ax is None:
        _, ax = plt.subplots(figsize=(14, 7))

    df = df_plot.copy().fillna(0)
    labels = _month_labels(df.index)
    cl = _color_list(df, colors)

    x = np.arange(len(labels))
    width = 0.55
    bottoms = np.zeros(len(labels))

    bars_info = []
    for i, col in enumerate(df.columns):
        vals = df[col].values.astype(float)
        bars = ax.bar(x, vals, width, bottom=bottoms, color=cl[i], label=col)
        bars_info.append((vals, bottoms.copy(), cl[i]))
        bottoms += vals

    # --- labels inside bars ---
    for vals, bot, _ in bars_info:
        for xi, (v, b) in enumerate(zip(vals, bot)):
            if v > 2.5:   # skip tiny slivers
                txt = f"{v:.2f}%" if percent else _fmt_num(v)
                ax.text(xi, b + v / 2, txt,
                        ha='center', va='center',
                        fontsize=7, color='white', fontweight='bold',
                        clip_on=True)

    ax.set_xticks(x)
    ax.set_xticklabels(labels, rotation=45, ha='right', fontsize=8)
    ax.set_title(title, fontsize=10, fontweight='bold', pad=6)
    ax.set_xlabel("Month", fontsize=8)
    ax.set_ylabel(ylabel, fontsize=8)

    if percent:
        ax.set_ylim(0, 105)
        ax.yaxis.set_major_formatter(mticker.PercentFormatter())
    else:
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(
            lambda v, _: _fmt_num(v)))

    ax.legend(loc='upper center', bbox_to_anchor=(0.5, -0.28),
              ncol=min(len(df.columns), 5), frameon=False, fontsize=8)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    return ax


# ─────────────────────────────────────────────────────────────
# LINE CHART
# ─────────────────────────────────────────────────────────────
def plot_line(df_plot, title, ylabel, colors=None, percent=True, ax=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(14, 7))

    df = df_plot.copy().fillna(0)
    labels = _month_labels(df.index)
    cl = _color_list(df, colors)
    x = np.arange(len(labels))

    for i, col in enumerate(df.columns):
        vals = df[col].values.astype(float)
        ax.plot(x, vals, marker='o', color=cl[i], linewidth=1.8,
                markersize=5, label=col)
        for xi, v in enumerate(vals):
            txt = f"{v:.2f}%" if percent else _fmt_num(v)
            ax.annotate(txt, (xi, v),
                        textcoords="offset points", xytext=(0, 6),
                        ha='center', fontsize=6.5, color=cl[i])

    ax.set_xticks(x)
    ax.set_xticklabels(labels, rotation=45, ha='right', fontsize=8)
    ax.set_title(title, fontsize=10, fontweight='bold', pad=6)
    ax.set_xlabel("Month", fontsize=8)
    ax.set_ylabel(ylabel, fontsize=8)
    ax.margins(x=0.05)

    if percent:
        ax.yaxis.set_major_formatter(mticker.PercentFormatter())

    ax.legend(loc='upper center', bbox_to_anchor=(0.5, -0.28),
              ncol=min(len(df.columns), 5), frameon=False, fontsize=8)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    return ax


# ─────────────────────────────────────────────────────────────
# STACKED BAR  +  OVERLAY LINE  (page-1 style with decline rate)
# ─────────────────────────────────────────────────────────────
def plot_stacked_bar_with_line(df_bar, series_line, title, ylabel,
                               colors=None, line_color='red',
                               line_label='Decline Rate %', ax=None):
    """
    df_bar       – wide DataFrame with stacked bar columns (e.g. Approved, Declined)
    series_line  – Series aligned to df_bar.index (e.g. overall decline-rate %)
    """
    if ax is None:
        _, ax = plt.subplots(figsize=(14, 7))

    df = df_bar.copy().fillna(0)
    labels = _month_labels(df.index)
    cl = _color_list(df, colors)

    x = np.arange(len(labels))
    width = 0.55
    bottoms = np.zeros(len(labels))

    for i, col in enumerate(df.columns):
        vals = df[col].values.astype(float)
        ax.bar(x, vals, width, bottom=bottoms, color=cl[i], label=col)
        bottoms += vals

    ax.set_xlabel("Month", fontsize=8)
    ax.set_ylabel(ylabel, fontsize=8)
    ax.set_xticks(x)
    ax.set_xticklabels(labels, rotation=45, ha='right', fontsize=8)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(
        lambda v, _: _fmt_num(v)))

    # secondary axis for line
    ax2 = ax.twinx()
    line_vals = series_line.reindex(df_bar.index).fillna(0).values.astype(float)
    ax2.plot(x, line_vals, color=line_color, marker='o',
             linewidth=2, markersize=5, label=line_label)
    for xi, v in enumerate(line_vals):
        ax2.annotate(f"{v:.2f}%", (xi, v),
                     textcoords="offset points", xytext=(0, 6),
                     ha='center', fontsize=6.5, color=line_color)
    ax2.set_ylabel("Decline Rate %", fontsize=8, color=line_color)
    ax2.yaxis.set_major_formatter(mticker.PercentFormatter())
    ax2.spines['top'].set_visible(False)

    # combined legend
    handles1, labels1 = ax.get_legend_handles_labels()
    handles2, labels2 = ax2.get_legend_handles_labels()
    ax.legend(handles1 + handles2, labels1 + labels2,
              loc='upper center', bbox_to_anchor=(0.5, -0.28),
              ncol=min(len(df.columns) + 1, 6), frameon=False, fontsize=8)
    ax.set_title(title, fontsize=10, fontweight='bold', pad=6)
    ax.spines['top'].set_visible(False)
    return ax


# ─────────────────────────────────────────────────────────────
# DUAL-AXIS BAR + LINE  (convenience alias kept for compat)
# ─────────────────────────────────────────────────────────────
def plot_dual_axis_bar_line(df_bar, series_line, title, ylabel,
                            colors=None, ax=None):
