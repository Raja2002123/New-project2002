def load_data(path):
    """Load the Excel file and return cleaned DataFrame."""
    print(f"Loading {path} ...")
    df = pd.read_excel(path, sheet_name='Auth Decline Summary')

    # Normalise column names
    df.columns = [str(c).strip() for c in df.columns]

    # Expected columns (adjust if yours differ):
    # country, month, network, CP_CNP, BIN, cardtype,
    # decisioning, tag, type, DECI_CD_ORIG, DECI_CD, TRANSACTION_ADVICE_XCD,
    # ExRate, txns, AMT, amt_usd

    # Parse month → period label
    df['month'] = df['month'].astype(str).str.strip()
    # Convert "Dec-25" → "Dec25", "Dec25" stays, etc.
    df['month'] = df['month'].str.replace('-', '', regex=False)
    df['month'] = df['month'].str.replace(' ', '', regex=False)

    # Standardise decisioning
    df['decisioning'] = df['decisioning'].astype(str).str.strip()

    # Approved / Declined flag
    df['is_approved'] = df['decisioning'].str.contains('Approved', case=False, na=False)
    df['is_declined'] = df['decisioning'].str.contains('Declined', case=False, na=False)

    # Decline category using 'tag' column
    df['tag'] = df['tag'].astype(str).str.strip()

    def classify_decline(row):
        if not row['is_declined']:
            return None
        tag = str(row['tag']).upper()
        if 'FALCON' in tag:
            return 'Falcon Decline'
        if 'STIP' in tag:
            return 'STIP Decline'
        if any(x in tag for x in ['INSUFF','CASH_LINE','CREDIT_LINE']):
            return 'Credit Related Decline'
        if tag in ['NAN','']:
            return 'Other Decline'
        return 'Other Decline'

    # Use 'type' column mapping if available
    def classify_by_type(row):
        if not row['is_declined']:
            return None
        t = str(row.get('type','')).strip().upper()
        tag = str(row['tag']).upper()
        if 'FALCON' in tag:
            return 'Falcon Decline'
        if 'STIP' in tag or 'STIPDEC' in str(row.get('tag','')):
            return 'STIP Decline'
        if t in ['O','I'] or any(x in tag for x in ['INSUFF','CASH','CREDIT']):
            return 'Credit Related Decline'
        return 'Other Decline'

    df['decline_cat'] = df.apply(classify_by_type, axis=1)

    # STIP vs Non-STIP
    df['stip_flag'] = df['tag'].str.upper().str.contains('STIP', na=False)

    # CP / CNP
    df['cp_cnp'] = df['CP_CNP'].astype(str).str.strip().str.upper()

    # Card type
    df['cardtype'] = df['cardtype'].astype(str).str.strip().str.upper()

    # CRD granular
    df['crd_sub'] = df.apply(lambda r: (
        'Insuff Decline' if 'INSUFF' in str(r['tag']).upper()
        else 'Cash Line' if 'CASH_LINE' in str(r['tag']).upper()
        else 'Credit Line' if 'CREDIT_LINE' in str(r['tag']).upper()
        else None
    ) if r['is_declined'] else None, axis=1)

    print(f"  Rows: {len(df):,}  |  Months: {sorted(df['month'].unique())}")
    return df

