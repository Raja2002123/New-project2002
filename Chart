def monthly_totals(df):
    """Return monthly approved/declined counts and amounts."""
    rows = []
    for m in MONTH_ORDER:
        sub = df[df['month'] == m]
        if sub.empty:
            continue
        approved_n = sub.loc[sub['is_approved'], 'txns'].sum()
        declined_n = sub.loc[sub['is_declined'], 'txns'].sum()
        total_n    = sub['txns'].sum()
        approved_s = sub.loc[sub['is_approved'], 'amt_usd'].sum()
        declined_s = sub.loc[sub['is_declined'], 'amt_usd'].sum()
        total_s    = sub['amt_usd'].sum()
        rows.append(dict(
            month=m,
            approved_n=approved_n, declined_n=declined_n, total_n=total_n,
            approved_s=approved_s, declined_s=declined_s, total_s=total_s,
            decline_rate_n=declined_n/total_n if total_n else 0,
            decline_rate_s=declined_s/total_s if total_s else 0,
        ))
    return pd.DataFrame(rows)

def monthly_by_cat(df, cat_col='decline_cat'):
    """Return monthly counts / amounts per decline category."""
    cats = ['Credit Related Decline','Falcon Decline','Other Decline','STIP Decline']
    rows = []
    for m in MONTH_ORDER:
        sub = df[(df['month'] == m) & df['is_declined']]
        total_n = df[df['month'] == m]['txns'].sum()
        total_s = df[df['month'] == m]['amt_usd'].sum()
        for cat in cats:
            cs = sub[sub[cat_col] == cat]
            rows.append(dict(
                month=m, cat=cat,
                n=cs['txns'].sum(), s=cs['amt_usd'].sum(),
                total_n=total_n, total_s=total_s,
            ))
    out = pd.DataFrame(rows)
    out['rate_n'] = out['n'] / out['total_n']
    out['rate_s'] = out['s'] / out['total_s']
    return out

def monthly_by_card(df):
    """Return monthly counts/amounts per card type."""
    cards = df['cardtype'].unique()
    rows = []
    for m in MONTH_ORDER:
        sub = df[df['month'] == m]
        total_n = sub['txns'].sum()
        total_s = sub['amt_usd'].sum()
        for c in cards:
            cs = sub[sub['cardtype'] == c]
            rows.append(dict(month=m, card=c,
                             n=cs['txns'].sum(), s=cs['amt_usd'].sum(),
                             total_n=total_n, total_s=total_s))
    return pd.DataFrame(rows)

def monthly_stip(df):
    rows = []
    for m in MONTH_ORDER:
        sub = df[df['month'] == m]
        stip   = sub[sub['stip_flag'] & sub['is_declined']]
        nstip  = sub[(~sub['stip_flag']) & sub['is_declined']]
        total  = sub[sub['is_declined']]
        rows.append(dict(
            month=m,
            stip_n=stip['txns'].sum(), nstip_n=nstip['txns'].sum(),
            stip_s=stip['amt_usd'].sum(), nstip_s=nstip['amt_usd'].sum(),
            total_n=sub['txns'].sum(), total_s=sub['amt_usd'].sum(),
            dec_n=total['txns'].sum(), dec_s=total['amt_usd'].sum(),
        ))
    return pd.DataFrame(rows)

def monthly_cp(df):
    rows = []
    for m in MONTH_ORDER:
        sub = df[df['month'] == m]
        cp  = sub[sub['cp_cnp'] == 'CP']
        cnp = sub[sub['cp_cnp'] == 'CNP']
        rows.append(dict(
            month=m,
            cp_n=cp['txns'].sum(), cnp_n=cnp['txns'].sum(),
            cp_s=cp['amt_usd'].sum(), cnp_s=cnp['amt_usd'].sum(),
            total_n=sub['txns'].sum(), total_s=sub['amt_usd'].sum(),
        ))
    return pd.DataFrame(rows)

