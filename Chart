import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import numpy as np
from matplotlib.backends.backend_pdf import PdfPages
from charts import (
    plot_bar, plot_line, plot_stacked_bar_with_line,
    plot_table, plot_dual_axis_bar_line
)

# ─────────────────────────────────────────────
# 1. LOAD & PREPARE DATA
# ─────────────────────────────────────────────
def load_data(excel_path, sheet_name="Auth Decline Summary"):
    df = pd.read_excel(excel_path, sheet_name=sheet_name)
    df.columns = df.columns.str.strip().str.lower()
    # Normalise column names
    df.rename(columns={
        'cp_cnp': 'CP_CNP',
        'cardtype': 'cardtype',
        'decisioning': 'decisioning',
        'tag': 'tag',
        'type': 'type',
        'network': 'network',
        'txns': 'txns',
        'amt_usd': 'amt_usd',
        'month': 'month',
    }, inplace=True)

    df['month'] = pd.to_datetime(df['month'], format='%b-%y', errors='coerce')
    df = df.dropna(subset=['month'])
    df = df[df['month'].dt.year == 2025]
    return df

# ─────────────────────────────────────────────
# 2. KPI HELPERS
# ─────────────────────────────────────────────
def to_pct(df):
    df = df.fillna(0)
    total = df.sum(axis=1)
    return df.div(total, axis=0).mul(100).round(2)

def approved_declined_kpi(df):
    kpi = df.groupby(['month', 'decisioning'])['txns'].sum().unstack(fill_value=0)
    return to_pct(kpi)

def approved_declined_kpi_usd(df):
    kpi = df.groupby(['month', 'decisioning'])['amt_usd'].sum().unstack(fill_value=0)
    return to_pct(kpi)

def transaction_decline_kpi(df):
    return df.groupby(['month', 'decisioning'])['txns'].sum().unstack(fill_value=0)

def transaction_decline_kpi_usd(df):
    return df.groupby(['month', 'decisioning'])['amt_usd'].sum().unstack(fill_value=0)

def cp_cnp_kpi(df):
    cp = df.groupby(['month', 'CP_CNP'])['txns'].sum().unstack(fill_value=0)
    return to_pct(cp)

def cp_cnp_kpi_usd(df):
    cp = df.groupby(['month', 'CP_CNP'])['amt_usd'].sum().unstack(fill_value=0)
    return to_pct(cp)

def _declines(df):
    return df[df['decisioning'].str.contains('declined', case=False, na=False)].copy()

def _credit_list_remap(df):
    credit_list = ["Insuff_Decline", "Cash_Line", "Credit_Line"]
    df = df.copy()
    df['type'] = df['type'].mask(df['type'].isin(credit_list), "Credit Related Decline")
    return df

def _waterfall_filter(df):
    return df[df['type'].str.contains(
        'STIP_DECLINE|_Other declines|FALCON_DECLINE|Credit Related Decline',
        case=False, na=False)]

# Decline by type (# and $) – overall
def decline_type_kpi(df):
    d = _declines(df)
    d = _credit_list_remap(d)
    d = _waterfall_filter(d)
    pivot = d.groupby(['month', 'type'])['txns'].sum().unstack(fill_value=0)
    # keep count for rate
    total = df.groupby('month')['txns'].sum()
    rate = pivot.div(total, axis=0).mul(100).round(4)
    return pivot, rate, to_pct(pivot)

def decline_type_kpi_usd(df):
    d = _declines(df)
    d = _credit_list_remap(d)
    d = _waterfall_filter(d)
    pivot = d.groupby(['month', 'type'])['amt_usd'].sum().unstack(fill_value=0)
    total = df.groupby('month')['amt_usd'].sum()
    rate = pivot.div(total, axis=0).mul(100).round(4)
    return pivot, rate, to_pct(pivot)

# STIP vs Non-STIP
def stip_kpi(df):
    d = _declines(df)
    pivot = d.groupby(['month', 'tag'])['txns'].sum().unstack(fill_value=0)
    return to_pct(pivot)

def stip_kpi_usd(df):
    d = _declines(df)
    pivot = d.groupby(['month', 'tag'])['amt_usd'].sum().unstack(fill_value=0)
    return to_pct(pivot)

def stip_rate_kpi(df):
    d = _declines(df)
    pivot = d.groupby(['month', 'tag'])['txns'].sum().unstack(fill_value=0)
    total = df.groupby('month')['txns'].sum()
    return pivot.div(total, axis=0).mul(100).round(4)

def stip_rate_kpi_usd(df):
    d = _declines(df)
    pivot = d.groupby(['month', 'tag'])['amt_usd'].sum().unstack(fill_value=0)
    total = df.groupby('month')['amt_usd'].sum()
    return pivot.div(total, axis=0).mul(100).round(4)

# CRD Granular
def crd_granular_kpi(df):
    d = _declines(df)
    d = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    pivot = d.groupby(['month', 'type'])['txns'].sum().unstack(fill_value=0)
    total = df.groupby('month')['txns'].sum()
    pct_of_total = pivot.div(total, axis=0).mul(100).round(4)
    return to_pct(pivot), pct_of_total

def crd_granular_kpi_usd(df):
    d = _declines(df)
    d = d[d['type'].str.contains('Insuff_Decline|Cash_Line|Credit_Line', case=False, na=False)]
    pivot = d.groupby(['month', 'type'])['amt_usd'].sum().unstack(fill_value=0)
    total = df.groupby('month')['amt_usd'].sum()
    pct_of_total = pivot.div(total, axis=0).mul(100).round(4)
    return to_pct(pivot), pct_of_total

# Credit Related Decline % of Total
def crd_pct_total(df):
    d = _declines(df)
    d = d[d['type'].isin(["Insuff_Decline", "Cash_Line", "Credit_Line"])]
    crd_txns = d.groupby('month')['txns'].sum()
    total_txns = df.groupby('month')['txns'].sum()
    crd_txns_usd = d.groupby('month')['amt_usd'].sum()
    total_usd = df.groupby('month')['amt_usd'].sum()
    return (crd_txns / total_txns * 100).round(4), (crd_txns_usd / total_usd * 100).round(4)

def crd_pct_decline(df):
    d = _declines(df)
    crd = d[d['type'].isin(["Insuff_Decline", "Cash_Line", "Credit_Line"])]
    crd_txns = crd.groupby('month')['txns'].sum()
    total_decline = d.groupby('month')['txns'].sum()
    crd_txns_usd = crd.groupby('month')['amt_usd'].sum()
    total_decline_usd = d.groupby('month')['amt_usd'].sum()
    return (crd_txns / total_decline * 100).round(4), (crd_txns_usd / total_decline_usd * 100).round(4)

# Card Type distribution (all txns)
def card_type_kpi(df):
    EXCL = ['TITANIUM', 'TITANIUM2', 'WORLD']
    d = df[~df['cardtype'].isin(EXCL)]
    pivot = d.groupby(['month', 'cardtype'])['txns'].sum().unstack(fill_value=0)
    return to_pct(pivot)

def card_type_kpi_usd(df):
    EXCL = ['TITANIUM', 'TITANIUM2', 'WORLD']
    d = df[~df['cardtype'].isin(EXCL)]
    pivot = d.groupby(['month', 'cardtype'])['amt_usd'].sum().unstack(fill_value=0)
