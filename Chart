    cat_rows = []
    for cat in CATS:
        cat_rows.append([fk(df[(df['month'] == m) & (df['cat'] == cat)]['txns'].sum()) for m in MONTHS])
    cat_rows.append([fk(mt.loc[mt['month'] == m, 'dn'].values[0]) for m in MONTHS])
    draw_table(axes[2], cat_rows,
        [c.replace(' Decline', '') for c in CATS] + ['Total #'],
        '# Decline Count – By Category', '#6A1B9A')

    fig.tight_layout()
    return fig2buf(fig)

# ── Main ─────────────────────────────────────────────────────
def main():
    path = sys.argv[1] if len(sys.argv) > 1 else 'AE_Auth_Decline_Summary.xlsx'
    print(f'Loading: {path}')
    df = load(path)
    mt = agg_monthly(df)
    dc = agg_cat(df, mt)

    print('Building charts...')
    pages = [
        page_overview(mt),
        page_by_type(dc),
        page_by_card(df),
        page_stip_cp(df),
        page_tables(df, mt),
    ]

    out = 'Credit_Card_Decline_Dashboard.pdf'
    doc = SimpleDocTemplate(out, pagesize=landscape(A3),
                            leftMargin=0.3*inch, rightMargin=0.3*inch,
                            topMargin=0.3*inch,  bottomMargin=0.3*inch)
    pw = landscape(A3)[0] - 0.6*inch
    story = []
    for i, buf in enumerate(pages):
        story.append(RLImage(buf, width=pw, height=pw*0.56))
        if i < len(pages) - 1:
            story.append(PageBreak())
    doc.build(story)
    print(f'✅  Saved → {out}')

if __name__ == '__main__':
    main()
