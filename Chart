def pg_cp_cnp(pdf, df):
    pt,pu,rtt,rtu,rt,ru = kpi_cp_cnp(df)
    fig, gs = page(4,2,"Card Present vs Card Not Present")
    plot_bar(pt,"Monthly Rate (#) – CP/CNP",ax=ax(fig,gs,0,0))
    plot_bar(pu,"Monthly Rate ($) – CP/CNP",ax=ax(fig,gs,0,1))
