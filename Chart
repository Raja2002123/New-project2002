import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
from matplotlib.backends.backend_pdf import PdfPages
from charts import plot_bar, plot_line, plot_table, plot_bar_line, plot_decline_rate_line, plot_decline_waterfall_bar

EXCEL_PATH = "/home/claude/AE_Auth_Decline_Summary.xlsx"
PDF_PATH   = "/home/claude/AE_Auth_Decline_Summary_data.pdf"
SHEET      = "Auth Decline Summary"
YEAR       = 2025
EXCLUDE    = ["TITANIUM","TITANIUM2","WORLD"]
CRD_TYPES  = ["Insuff_Decline","Cash_Line","Credit_Line"]
WF_FILTER  = "Credit Related Decline|STIP_DECLINE|_Other declines|FALCON_DECLINE"
RENAME     = {"Credit Related Decline":"Credit Related Decline","FALCON_DECLINE":"Falcon Decline",
              "_Other declines":"Other Decline","STIP_DECLINE":"STIP Decline"}
CARDS      = ["PLATINUM","INFINITE","CASHBACK","MNH REWARDS PLUS","SAADIQ","X CASHBACK"]

# ── Data load ──────────────────────────────────────────────────────────────────
def load(path, sheet):
    df = pd.read_excel(path, sheet_name=sheet)
    df.columns = df.columns.str.strip()
    df["month"] = pd.to_datetime(df["month"], format="%b-%y")
    df = df[df["month"].dt.year == YEAR].copy()
    for c in ["decisioning","tag","type","cardtype","CP_CNP","network"]:
        if c in df.columns: df[c] = df[c].astype(str).str.strip()
    return df

# ── Helpers ────────────────────────────────────────────────────────────────────
def to_pct(df): 
    df = df.fillna(0)
    return (df.div(df.sum(axis=1).replace(0,np.nan), axis=0)*100).round(2)

def declined(df): return df[df["decisioning"].str.lower().str.contains("decline")].copy()

def remap(df):
    df = df.copy(); df["type"] = df["type"].mask(df["type"].isin(CRD_TYPES),"Credit Related Decline"); return df

def grp(df, by, col): return df.groupby(["month", by])[col].sum().unstack(fill_value=0)

def rate(num, den): return num.div(den, axis=0).mul(100).round(2)

# ── KPIs ───────────────────────────────────────────────────────────────────────
def kpi_approv(df):
    raw = df.groupby(["month","decisioning"])[["txns","amt_usd"]].sum().unstack(fill_value=0)
    raw.columns = ["_".join(c) for c in raw.columns]
    t = raw[[c for c in raw.columns if c.startswith("txns_")]].rename(columns=lambda c: c[5:])
    u = raw[[c for c in raw.columns if c.startswith("amt_usd_")]].rename(columns=lambda c: c[8:])
    return raw, to_pct(t), to_pct(u)

def kpi_dec_rate(df):
    g = df.groupby(["month","decisioning"])[["txns","amt_usd"]].sum().unstack(fill_value=0)
    g.columns = ["_".join(c) for c in g.columns]
    tot_t = g[[c for c in g.columns if c.startswith("txns_")]].sum(axis=1)
    tot_u = g[[c for c in g.columns if c.startswith("amt_usd_")]].sum(axis=1)
    dt = g[[c for c in g.columns if "decline" in c.lower() and c.startswith("txns_")]].sum(axis=1)
    du = g[[c for c in g.columns if "decline" in c.lower() and c.startswith("amt_usd_")]].sum(axis=1)
    return pd.DataFrame({"# Decline Rate":(dt/tot_t*100).round(2)}), pd.DataFrame({"$ Decline Rate":(du/tot_u*100).round(2)})

def kpi_by_type(df):
    d = declined(df); d = remap(d); d["type"] = d["type"].map(RENAME).fillna("Other Decline")
    rt, ru = grp(d,"type","txns"), grp(d,"type","amt_usd")
    tot_t, tot_u = df.groupby("month")["txns"].sum(), df.groupby("month")["amt_usd"].sum()
    return rt, ru, rate(rt,tot_t), rate(ru,tot_u), to_pct(rt), to_pct(ru)

def kpi_crd(df):
    d = declined(df); crd = d[d["type"].isin(CRD_TYPES)]
    tot_t, tot_u = df.groupby("month")["txns"].sum(), df.groupby("month")["amt_usd"].sum()
    dtot_t, dtot_u = d.groupby("month")["txns"].sum(), d.groupby("month")["amt_usd"].sum()
    rt, ru = grp(crd,"type","txns"), grp(crd,"type","amt_usd")
    st, su = rt.sum(axis=1), ru.sum(axis=1)
    return (st/tot_t*100).round(2).rename("CRD%#"), (su/tot_u*100).round(2).rename("CRD%$"), \
           (st/dtot_t*100).round(2).rename("CRD%Dec#"), (su/dtot_u*100).round(2).rename("CRD%Dec$"), \
           to_pct(rt), to_pct(ru), rt, ru

def kpi_other(df):
    d = declined(df)
    oth = d[d["type"].str.startswith("_") | d["type"].isin(["ATM_Decline","CVV_Decline",
           "Exceeds withdrawal amount limit - CP","Exceeds withdrawal amount limit - CNP"])]
    tot_t, tot_u = df.groupby("month")["txns"].sum(), df.groupby("month")["amt_usd"].sum()
    dtot_t, dtot_u = d.groupby("month")["txns"].sum(), d.groupby("month")["amt_usd"].sum()
    rt, ru = grp(oth,"type","txns"), grp(oth,"type","amt_usd")
    return rate(rt,tot_t), rate(ru,tot_u), rate(rt,dtot_t), rate(ru,dtot_u), rt, ru

def kpi_cp_cnp(df):
    rt, ru = grp(df,"CP_CNP","txns"), grp(df,"CP_CNP","amt_usd")
    dt, du = grp(declined(df),"CP_CNP","txns"), grp(declined(df),"CP_CNP","amt_usd")
    return to_pct(rt), to_pct(ru), rate(dt,rt), rate(du,ru), rt, ru

def kpi_card(df):
    df = df[~df["cardtype"].isin(EXCLUDE)]
    rt, ru = grp(df,"cardtype","txns"), grp(df,"cardtype","amt_usd")
    dt, du = grp(declined(df),"cardtype","txns"), grp(declined(df),"cardtype","amt_usd")
    return to_pct(rt), to_pct(ru), rate(dt,rt), rate(du,ru), rt, ru

def kpi_per_card(df, card):
    d = declined(df); d = remap(d); d = d[d["type"].str.contains(WF_FILTER, na=False)]
    d = d[d["cardtype"]==card]; d["type"] = d["type"].map(RENAME).fillna("Other Decline")
    rt, ru = grp(d,"type","txns"), grp(d,"type","amt_usd")
    base = df[df["cardtype"]==card].groupby("month")[["txns","amt_usd"]].sum()
    return to_pct(rt), to_pct(ru), rate(rt,base["txns"]), rate(ru,base["amt_usd"]), rt, ru

def kpi_stip(df):
    rt, ru = grp(df,"tag","txns"), grp(df,"tag","amt_usd")
    dt, du = grp(declined(df),"tag","txns"), grp(declined(df),"tag","amt_usd")
    return to_pct(rt), to_pct(ru), rate(dt,rt), rate(du,ru), to_pct(dt), to_pct(du), dt, du

def kpi_wf(df, segment, col):
    d = declined(df); d = remap(d); d = d[d["type"].str.contains(WF_FILTER, na=False)]
    d = d[d[col]==segment]; d["type"] = d["type"].map(RENAME).fillna("Other Decline")
    rt, ru = grp(d,"type","txns"), grp(d,"type","amt_usd")
    base = df[df[col]==segment].groupby("month")[["txns","amt_usd"]].sum()
    return to_pct(rt), to_pct(ru), rate(rt,base["txns"]), rate(ru,base["amt_usd"]), rt, ru

# ── Page helpers ───────────────────────────────────────────────────────────────
def page(rows, cols, title=None):
    fig = plt.figure(figsize=(22,28))
    gs  = gridspec.GridSpec(rows, cols, figure=fig, hspace=0.55, wspace=0.35, left=0.06, right=0.97, top=0.95, bottom=0.04)
    if title: fig.suptitle(title, fontsize=13, fontweight="bold", y=0.98)
    return fig, gs

def ax(fig, gs, r, c, rs=1, cs=1): return fig.add_subplot(gs[r:r+rs, c:c+cs])

def save(pdf, fig): pdf.savefig(fig, bbox_inches="tight"); plt.close(fig)

def quad(pdf, fig, gs, r, data, titles, pcts):
    """Plot bar+line+table+table in rows r, r+1, r+2 using (d0,d1) pairs."""
    for ci, (df2, t, p) in enumerate(zip(data, titles, pcts)):
        plot_bar(df2, t, ax=ax(fig,gs,r,ci), percent=p)
        plot_line(df2, t, ax=ax(fig,gs,r+1,ci), percent=p)
        plot_table(df2, t, percent=p, ax=ax(fig,gs,r+2,ci))

# ── Pages ──────────────────────────────────────────────────────────────────────
def pg_overview(pdf, df):
    raw, pt, pu = kpi_approv(df); rt, ru = kpi_dec_rate(df)
    dc = [c for c in pt.columns if "decline" in c.lower()]; ac = [c for c in pt.columns if "approve" in c.lower()]
    traw = raw[[c for c in raw.columns if c.startswith("txns_")]].rename(columns=lambda c:c[5:])
    uraw = raw[[c for c in raw.columns if c.startswith("amt_usd_")]].rename(columns=lambda c:c[8:])
    fig, gs = page(4,2, "Transaction & Decline Rate Overview")
    plot_bar_line(traw, rt, "# Transaction & # Decline Rate", bar_ylabel="# Transactions", ax=ax(fig,gs,0,0))
    plot_bar_line(uraw, ru, "$ Transaction & $ Decline Rate", bar_ylabel="$ Amount",       ax=ax(fig,gs,0,1))
    plot_bar(pt[ac+dc], "Monthly Rate (#) – By Decision", ax=ax(fig,gs,1,0))
    plot_bar(pu[ac+dc], "Monthly Rate ($) – By Decision", ax=ax(fig,gs,1,1))
    plot_table(traw, "# Approved vs Declined", ax=ax(fig,gs,2,0))
    plot_table(uraw, "$ Approved vs Declined", ax=ax(fig,gs,2,1))
    plot_table(rt, "# Decline Rate", percent=True, ax=ax(fig,gs,3,0))
    plot_table(ru, "$ Decline Rate", percent=True, ax=ax(fig,gs,3,1))
    save(pdf, fig)

def pg_type(pdf, df):
    rt,ru,ratet,rateu,pt,pu = kpi_by_type(df)
    fig, gs = page(5,2, "Decline Rate & Distribution – By Type")
    plot_decline_rate_line(ratet,"# Decline Rate – By Type",ax=ax(fig,gs,0,0))
    plot_decline_rate_line(rateu,"$ Decline Rate – By Type",ax=ax(fig,gs,0,1))
    plot_table(rt,"# Declines by Type",ax=ax(fig,gs,1,0)); plot_table(ru,"$ Declines by Type",ax=ax(fig,gs,1,1))
    plot_decline_waterfall_bar(pt,"# Decline Waterfall",ax=ax(fig,gs,2,0))
    plot_decline_waterfall_bar(pu,"$ Decline Waterfall",ax=ax(fig,gs,2,1))
    plot_line(pt,"# Decline Mix",ax=ax(fig,gs,3,0)); plot_line(pu,"$ Decline Mix",ax=ax(fig,gs,3,1))
    plot_table(pt,"# Decline Mix %",percent=True,ax=ax(fig,gs,4,0)); plot_table(pu,"$ Decline Mix %",percent=True,ax=ax(fig,gs,4,1))
    save(pdf, fig)

def pg_crd(pdf, df):
    a,b,c_,d_,gpt,gpu,grt,gru = kpi_crd(df)
    tot_t, tot_u = df.groupby("month")["txns"].sum(), df.groupby("month")["amt_usd"].sum()
    fig, gs = page(5,2, "Credit Related Decline – Deep Dive")
