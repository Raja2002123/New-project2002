        plot_bar(pu,f"{card} – $ Decline Mix",ax=ax(fig,gs,1,1))
        plot_table(rt,f"{card} – Raw #",ax=ax(fig,gs,2,0)); plot_table(ru,f"{card} – Raw $",ax=ax(fig,gs,2,1))
        plot_table(rtt,f"{card} – # Rate %",percent=True,ax=ax(fig,gs,3,0))
        plot_table(rtu,f"{card} – $ Rate %",percent=True,ax=ax(fig,gs,3,1))
        save(pdf, fig)

