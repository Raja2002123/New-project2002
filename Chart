import matplotlib.pyplot as plt
import pandas as pd
def plot_bar(df_plot,title,ylabel,percent=True,ax=None):#bar chart
    if ax is None:
        _,ax=plt.subplots(figsize=(20,18))
    df=df_plot.copy()
    df.index=df.index.strftime('%b-%y')
    df.plot(kind='bar',stacked=True,ax=ax)
    ax.tick_params(axis='x',rotation=0)
    ax.set_title(title)
    ax.set_xlabel("Month")
    ax.set_ylabel(ylabel)
    if percent:
        ax.set_ylim(0,100)
        ax.set_yticks(range(0,101,20))
        ax.set_yticklabels([f"{i}%" for i in range(0,101,20)])
        for c in ax.containers:
            #ax.bar_label(c,labels=[f"{round(v,2)}%"for v in c.datavalues],label_type='center')
            ax.bar_label(c,fmt='%.2f%%',label_type='center')
    ax.legend(
        loc='upper center',
        bbox_to_anchor=(0.5,-0.2),
        ncol=8,
        frameon=False,
        fontsize=9
    )
    plt.subplots_adjust(bottom=0.25,top=0.95,left=0.08,right=0.95)
    return ax
def plot_line(df_plot,title,ylabel,percent=True,ax=None):#line chart
    if ax is None:
        _,ax=plt.subplots(figsize=(20,18))
    df=df_plot.copy()
    df.index=pd.to_datetime(df.index)
    for col in df.columns:
        ax.plot(df.index,df[col],marker='o',label=col)
    if percent:
        for col in df.columns:
            for x,y in zip(df.index,df[col]):
                ax.text(x,y+1,f'{y:.2f}%',ha='center',va='bottom',fontsize=9)
    #df_plot.plot(kind='line',marker='o',ax=ax)
    ax.set_title(title)
    ax.set_xlabel("Month")
    ax.set_ylabel(ylabel)
    ax.set_xticks(df.index)
    ax.set_xticklabels([d.strftime('%b-%y') for d in df.index],rotation=45)
    ax.margins(x=0.05)
    if percent:
        ax.set_ylim(0,100)
        ax.set_yticks(range(0,101,20))
        ax.set_yticklabels([f"{i}%" for i in range(0,101,20)])
    ax.legend(
        loc='upper center',
        bbox_to_anchor=(0.5,-0.2),
        ncol=8,
        frameon=False,
        fontsize=9
    )
    plt.subplots_adjust(bottom=0.25,top=0.95,left=0.08,right=0.95)
    return ax
def plot_table(df_plot,title,percent=False,ax=None):#table
    if ax is None:
        _,ax=plt.subplots(figsize=(20,18))
    ax.axis('off')
    table_df=df_plot.copy()
    table_df.insert(0,'month',table_df.index.strftime('%b-%y'))
    if percent:
        table_df=table_df.round(2)
    table_df=table_df.reset_index(drop=True)
    table=ax.table(cellText=table_df.values,colLabels=table_df.columns,loc='center')
    table.auto_set_column_width(col=list(range(len(table_df.columns))))
    table.auto_set_font_size(False)
    table.set_fontsize(12)
    table.scale(1.8,2.2)
    ax.set_title(title)
    plt.subplots_adjust(bottom=0.25,top=0.95,left=0.08,right=0.95)
    return ax
