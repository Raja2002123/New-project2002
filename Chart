    plot_table(rtu,"$ Decline Rate %",percent=True,ax=ax(fig,gs,3,1))
    save(pdf, fig)

def pg_wf(pdf, df):
    fig, gs = page(4,2,"Decline Waterfall – CP vs CNP")
    for ci, seg in enumerate(["CP","CNP"]):
        pt,pu,rtt,rtu,rt,ru = kpi_wf(df, seg, "CP_CNP")
        plot_bar(pt,f"{seg} – # Waterfall",ax=ax(fig,gs,0,ci))
        plot_bar(pu,f"{seg} – $ Waterfall",ax=ax(fig,gs,1,ci))
        plot_table(rt,f"{seg} – Raw #",ax=ax(fig,gs,2,ci))
        plot_table(ru,f"{seg} – Raw $",ax=ax(fig,gs,3,ci))
    save(pdf, fig)

def pg_reason_rate(pdf, df):
    fig, gs = page(4,2,"Decline Rate by Reason – CP and CNP")
    for ci, seg in enumerate(["CP","CNP"]):
        pt,pu,rtt,rtu,_,_ = kpi_wf(df, seg, "CP_CNP")
        plot_line(rtt,f"{seg} – # Decline Rate by Reason",ax=ax(fig,gs,ci*2,0),ylim_top=5)
        plot_line(rtu,f"{seg} – $ Decline Rate by Reason",ax=ax(fig,gs,ci*2,1),ylim_top=15)
        plot_table(rtt,f"{seg} – # Rate %",percent=True,ax=ax(fig,gs,ci*2+1,0))
        plot_table(rtu,f"{seg} – $ Rate %",percent=True,ax=ax(fig,gs,ci*2+1,1))
    save(pdf, fig)

# ── Main ───────────────────────────────────────────────────────────────────────
def main():
    print("Loading …"); df = load(EXCEL_PATH, SHEET)
    print(f"  {len(df):,} rows | {df['month'].nunique()} months")
    with PdfPages(PDF_PATH) as pdf:
        pdf.infodict().update({"Title":"AE Auth Decline 2025","Subject":"Decline Analysis"})
        pg_overview(pdf,df); pg_type(pdf,df); pg_crd(pdf,df); pg_other(pdf,df)
        pg_card(pdf,df); pg_per_card(pdf,df); pg_stip(pdf,df)
        pg_cp_cnp(pdf,df); pg_wf(pdf,df); pg_reason_rate(pdf,df)
    print(f"Saved → {PDF_PATH}")

if __name__ == "__main__": main()
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import pandas as pd
import numpy as np

PALETTE = ["#2196F3","#4CAF50","#FF9800","#9C27B0","#F44336","#00BCD4","#8BC34A","#FF5722","#607D8B","#E91E63"]
DECLINE_COLORS = {"Credit Related Decline":"#2196F3","STIP_DECLINE":"#9C27B0","_Other declines":"#00BCD4",
                  "FALCON_DECLINE":"#FF9800","Other Decline":"#00BCD4","Falcon Decline":"#FF9800","STIP Decline":"#9C27B0"}

def _fmt(df):
    df = df.copy()
    if hasattr(df.index, "strftime"): df.index = df.index.strftime("%b-%y")
    return df

def _colors(cols): return [DECLINE_COLORS.get(c, PALETTE[i % len(PALETTE)]) for i, c in enumerate(cols)]
def _legend(ax, cols): ax.legend(loc="upper center", bbox_to_anchor=(0.5,-0.22), ncol=min(len(cols),6), frameon=False, fontsize=7)

def plot_bar(df_plot, title, ylabel="", percent=True, ax=None):
    if ax is None: _, ax = plt.subplots(figsize=(18,6))
    df = _fmt(df_plot)
    df.plot(kind="bar", stacked=True, ax=ax, color=_colors(df.columns.tolist()), width=0.65, edgecolor="white")
    ax.set(title=title, xlabel="Month", ylabel=ylabel)
    ax.tick_params(axis="x", rotation=0, labelsize=7); ax.tick_params(axis="y", labelsize=7)
    if percent:
        ax.set_ylim(0,105); ax.yaxis.set_major_formatter(mticker.PercentFormatter())
    for c in ax.containers:
        ax.bar_label(c, labels=[f"{b.get_height():.1f}%" if (percent and b.get_height()>=3) else "" for b in c],
                     label_type="center", fontsize=6, color="white", fontweight="bold")
    _legend(ax, df.columns); ax.grid(axis="y", linestyle="--", alpha=0.4)
    return ax

def plot_line(df_plot, title, ylabel="", percent=True, ax=None, ylim_top=None):
    if ax is None: _, ax = plt.subplots(figsize=(18,6))
    df = _fmt(df_plot); x = range(len(df))
    for i, col in enumerate(df.columns):
        y = df[col].values; c = _colors(df.columns.tolist())[i]
        ax.plot(x, y, marker="o", markersize=4, linewidth=1.5, label=col, color=c)
        for xi, yi in zip(x, y):
            if not np.isnan(yi):
                ax.annotate(f"{yi:.2f}%" if percent else f"{yi:.2f}", (xi,yi),
                            textcoords="offset points", xytext=(0,6), ha="center", fontsize=6, color=c)
    ax.set(title=title, xlabel="Month", ylabel=ylabel)
    ax.set_xticks(list(x)); ax.set_xticklabels(df.index.tolist(), rotation=45, ha="right", fontsize=7)
    ax.tick_params(axis="y", labelsize=7)
    if percent:
        ax.set_ylim(0, ylim_top or max(df.max().max()*1.25, 5))
        ax.yaxis.set_major_formatter(mticker.PercentFormatter())
    _legend(ax, df.columns); ax.grid(axis="y", linestyle="--", alpha=0.4)
    return ax

def plot_bar_line(bar_df, line_df, title, bar_ylabel="", line_ylabel="Decline Rate %", ax=None):
    if ax is None: _, ax = plt.subplots(figsize=(18,7))
    ax2 = ax.twinx()
    _fmt(bar_df).plot(kind="bar", stacked=True, ax=ax, color=_colors(bar_df.columns.tolist()), width=0.65, edgecolor="white", legend=False)
    ldf = _fmt(line_df); x = range(len(ldf))
    for col in ldf.columns:
        y = ldf[col].values
        ax2.plot(x, y, marker="o", markersize=4, linewidth=1.5, color="#F44336", label=col)
        for xi, yi in zip(x, y):
            if not np.isnan(yi): ax2.annotate(f"{yi:.1f}%",(xi,yi),textcoords="offset points",xytext=(0,6),ha="center",fontsize=6.5,color="#F44336")
    ax.set(title=title, xlabel="Month", ylabel=bar_ylabel); ax2.set_ylabel(line_ylabel, fontsize=8, color="#F44336")
    ax.tick_params(axis="x", rotation=0, labelsize=7); ax.tick_params(axis="y", labelsize=7)
    ax2.tick_params(axis="y", labelsize=7, colors="#F44336"); ax2.yaxis.set_major_formatter(mticker.PercentFormatter())
    h1,l1 = ax.get_legend_handles_labels(); h2,l2 = ax2.get_legend_handles_labels()
    ax.legend(h1+h2, l1+l2, loc="upper center", bbox_to_anchor=(0.5,-0.18), ncol=6, frameon=False, fontsize=7)
    ax.grid(axis="y", linestyle="--", alpha=0.4)
    return ax, ax2

def plot_table(df_plot, title, percent=False, ax=None):
    if ax is None: _, ax = plt.subplots(figsize=(18,3))
    ax.axis("off")
    df = _fmt(df_plot).T
    def fmt(v):
        if percent: return f"{v:.2f}%"
        if abs(v)>=1e6: return f"${v/1e6:.2f}M"
        if abs(v)>=1e3: return f"{v/1e3:.1f}K"
        return f"{v:.0f}"
    tbl = ax.table(cellText=[[fmt(v) for v in row] for row in df.values],
                   rowLabels=df.index.tolist(), colLabels=df.columns.tolist(), loc="center", cellLoc="center")
    tbl.auto_set_font_size(False); tbl.set_fontsize(7); tbl.scale(1,1.6)
    for (r,c), cell in tbl.get_celld().items():
        if r==0: cell.set_facecolor("#1565C0"); cell.set_text_props(color="white", fontweight="bold")
        elif c==-1: cell.set_facecolor("#E3F2FD"); cell.set_text_props(fontweight="bold")
        else: cell.set_facecolor("#FAFAFA" if r%2==0 else "white")
    ax.set_title(title, fontsize=9, fontweight="bold", pad=4)
    return ax

plot_decline_rate_line     = lambda df,t,y="",ax=None: plot_line(df,t,y,ax=ax,ylim_top=max(df.max().max()*1.4+0.5,10))
plot_decline_waterfall_bar = lambda df,t,y="% of Total Decline #",ax=None: plot_bar(df,t,y,ax=ax)
