        for xi, v in enumerate(vals):
            ax.text(xi, v + 0.5, f'{v:.2f}%', ha='center', fontsize=4, color=color)
    style(ax, 'Decline Rate %')
    ax.legend(fontsize=6)

    # CP/CNP distribution stacked bar
    ax = axes[1, 0]
    ax.set_title('Monthly Rate (#) – By CP/CNP', fontsize=8, fontweight='bold')
    cp_pct, cnp_pct = [], []
    for m in MONTHS:
        s = df[df['month'] == m]
        t = s['txns'].sum()
        cp = s[s['cp_cnp'] == 'CP']['txns'].sum() / t * 100 if t else 0
