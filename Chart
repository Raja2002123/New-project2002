        ax.set_title(title, fontsize=8, fontweight='bold')
        approved = mt[n_col if col==0 else 'as_'] / (1e3 if col==0 else 1e6)
        declined = mt[d_col if col==0 else 'ds']  / (1e3 if col==0 else 1e6)
