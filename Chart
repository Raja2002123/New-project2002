#load & prepare data
def load_data(excel_path,sheet_name):
    df=pd.read_excel(excel_path,sheet_name)
    df.columns.str.strip().str.lower()
    df['month']=pd.to_datetime(df['month'],format='%b-%y')
    df['month']=pd.to_datetime(df['month'])
    df=df[df['month'].dt.year==2025]#year-2025
    return df
#approved vs declined
def approved_declined_kpi(df):
    kpi=df.groupby(['month','decisioning'])['txns'].sum().unstack(fill_value=0)
    kpi['Total']=kpi.sum(axis=1)
    kpi_pct=kpi.div(kpi['Total'],axis=0)*100
    return kpi_pct
def approved_declined_kpi_usd(df):
    kpi_usd=df.groupby(['month','decisioning'])['amt_usd'].sum().unstack(fill_value=0)
    kpi_usd['Total']=kpi_usd.sum(axis=1)
    kpi_pct_usd=kpi_usd.div(kpi_usd['Total'],axis=0)*100
    return kpi_pct_usd
#cp vs cnp
def cp_cnp_kpi(df):
    cp_cnp=df.groupby(['month','CP_CNP'])['txns'].sum().unstack(fill_value=0)
    cp_cnp['Total']=cp_cnp.sum(axis=1)
    cp_cnp_pct=cp_cnp.div(cp_cnp['Total'],axis=0)*100
    return cp_cnp_pct
def cp_cnp_kpi_usd(df):
    cp_cnp_usd=df.groupby(['month','CP_CNP'])['amt_usd'].sum().unstack(fill_value=0)
    cp_cnp_usd['Total']=cp_cnp_usd.sum(axis=1)
    cp_cnp_pct_usd=cp_cnp_usd.div(cp_cnp_usd['Total'],axis=0)*100
    return cp_cnp_pct_usd
#percentage
def to_percentage(df):
    df=df.fillna(0)
    if df.empty or df.sum().sum()==0:
        return df
    return (df.div(df.sum(axis=1),axis=0)*100).round(2)
def convert_to_k(df):
    return df.where(df < 1000, df/1000)
def convert_to_m(df):
    return df.where(df < 1000000, df/1000000)
#decline Reasons
def decline_reason_kpi(df):
    declines=df[df['decisioning'].str.contains('declined',case=False,na=False)]
    reason=declines.groupby(['month','network'])['txns'].sum().unstack(fill_value=0)
    return to_percentage(reason)
def decline_reason_kpi_usd(df):
    declines_usd=df[df['decisioning'].str.contains('declined',case=False,na=False)]
