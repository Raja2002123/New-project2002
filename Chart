def fmt_k(v):
    if v >= 1_000_000: return f'{v/1_000_000:.1f}M'
    if v >= 1_000:     return f'{v/1_000:.0f}K'
    return str(int(v))

def fmt_m(v):
    return f'${v/1_000_000:.2f}M'

def pct(v): return f'{v*100:.1f}%'

def bar_labels(ax, bars, fmt_fn, fontsize=5, color='white', va='center'):
    for b in bars:
        h = b.get_height()
        if h > 0:
            ax.text(b.get_x()+b.get_width()/2, b.get_y()+h/2,
                    fmt_fn(h), ha='center', va=va, fontsize=fontsize, color=color)

def style_ax(ax, months, ylabel='', pct_y=False):
    ax.set_xticks(range(len(months)))
    ax.set_xticklabels(months, fontsize=6, rotation=45, ha='right')
    ax.tick_params(axis='y', labelsize=6)
    ax.set_ylabel(ylabel, fontsize=6)
    if pct_y:
        ax.yaxis.set_major_formatter(mticker.PercentFormatter(xmax=1, decimals=0))
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    ax.grid(axis='y', alpha=0.2, linewidth=0.5)

def fig_to_bytes(fig):
    buf = io.BytesIO()
    fig.savefig(buf, format='png', dpi=150, bbox_inches='tight')
    plt.close(fig)
    buf.seek(0)
    return buf

