#  PAGE-BUILDING UTILITIES
# ══════════════════════════════════════════════════════════════════════════════
def _new_fig():
    fig, axes = plt.subplots(3, 2, figsize=(22, 26))
    return fig, axes.flatten()

def _save(pdf, fig):
    plt.subplots_adjust(left=0.05, right=0.97,
                        top=0.95, bottom=0.08,
                        hspace=0.60, wspace=0.30)
    pdf.savefig(fig, bbox_inches='tight')
    plt.close(fig)

def _app_dec_cols(pct_df):
    """Return approved+declined columns in sorted order (no Total)."""
    return [c for c in pct_df.columns if str(c).strip().lower() != 'total']


