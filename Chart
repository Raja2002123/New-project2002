                                      colors=colors, ax=ax)


# ─────────────────────────────────────────────────────────────
# TABLE
# ─────────────────────────────────────────────────────────────
def plot_table(df_plot, title, percent=False, ax=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(14, 4))

    ax.axis('off')
    df = df_plot.copy().fillna(0)

    # Build display frame
    display = df.copy()
    if percent:
        display = display.applymap(lambda v: f"{v:.2f}%")
    else:
        display = display.applymap(_fmt_num)

    display.insert(0, 'Month', _month_labels(df.index))
    display = display.reset_index(drop=True)

    tbl = ax.table(
        cellText=display.values,
        colLabels=display.columns,
        loc='center',
        cellLoc='center',
    )
    tbl.auto_set_font_size(False)
    tbl.set_fontsize(7.5)
    tbl.scale(1.0, 1.6)

    # Header styling
    for j in range(len(display.columns)):
        cell = tbl[0, j]
        cell.set_facecolor('#1565C0')
        cell.set_text_props(color='white', fontweight='bold')

    # Alternating row colours
    for i in range(1, len(display) + 1):
        bg = '#EBF5FB' if i % 2 == 0 else 'white'
        for j in range(len(display.columns)):
            tbl[i, j].set_facecolor(bg)

    tbl.auto_set_column_width(list(range(len(display.columns))))
    ax.set_title(title, fontsize=9, fontweight='bold', pad=4)
    return ax


# ─────────────────────────────────────────────────────────────
# UTILITY
# ─────────────────────────────────────────────────────────────
def _fmt_num(v):
    """Format a number as K or M for axis/label display."""
    try:
        v = float(v)
    except (TypeError, ValueError):
        return str(v)
    if abs(v) >= 1_000_000:
        return f"{v/1_000_000:.2f}M"
    if abs(v) >= 1_000:
        return f"{v/1_000:.1f}K"
    return f"{v:.2f}"
