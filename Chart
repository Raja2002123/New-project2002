def load_data(excel_path, sheet_name):
    df = pd.read_excel(excel_path, sheet_name=sheet_name)

    # strip + lower all column names  (original code missed assignment)
    df.columns = [str(c).strip() for c in df.columns]

    # flexible rename to canonical names
    rename = {}
    for c in df.columns:
        lc = c.lower()
        if   lc == 'country_month':  rename[c] = 'month'      # pivot-table export
        elif lc == 'month':          rename[c] = 'month'
        elif lc == 'network':        rename[c] = 'network'
        elif lc == 'cp_cnp':         rename[c] = 'CP_CNP'
        elif lc == 'bin':            rename[c] = 'BIN'
        elif lc == 'cardtype':       rename[c] = 'cardtype'
        elif lc == 'decisioning':    rename[c] = 'decisioning'
        elif lc == 'tag':            rename[c] = 'tag'
        elif lc == 'type':           rename[c] = 'type'
        elif lc == 'exrate':         rename[c] = 'exrate'
        elif lc == 'txns':           rename[c] = 'txns'
        elif lc == 'amt':            rename[c] = 'amt'
        elif lc == 'amt_usd':        rename[c] = 'amt_usd'
    df = df.rename(columns=rename)

    # parse month  (handles 'Jan-25', 'Jan-2025', datetime objects)
    df['month'] = pd.to_datetime(df['month'], format='%b-%y',  errors='coerce').fillna(
                  pd.to_datetime(df['month'], format='%b-%Y',  errors='coerce')).fillna(
                  pd.to_datetime(df['month'],                   errors='coerce'))
    df = df.dropna(subset=['month'])
    df = df[df['month'].dt.year == 2025].copy()

    # numeric columns
    for col in ['txns', 'amt', 'amt_usd', 'exrate']:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)

    print(f"  Loaded {len(df):,} rows | months: {df['month'].dt.strftime('%b-%y').unique().tolist()}")
    return df


