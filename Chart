# ── helper ──────────────────────────────────────────────────────────────────
def to_percentage(df):
    df = df.fillna(0)
    if df.empty or df.sum().sum() == 0:
        return df
    totals = df.sum(axis=1).replace(0, np.nan)
    return (df.div(totals, axis=0) * 100).round(2)

def convert_to_k(df):  return df.where(df < 1000,    df / 1_000)
def convert_to_m(df):  return df.where(df < 1_000_000, df / 1_000_000)

# ── approved vs declined ─────────────────────────────────────────────────────
def approved_declined_kpi(df):
    kpi = df.groupby(['month','decisioning'])['txns'].sum().unstack(fill_value=0)
    kpi['Total'] = kpi.sum(axis=1)
    return kpi.div(kpi['Total'], axis=0).mul(100).round(2)

def approved_declined_kpi_usd(df):
    kpi = df.groupby(['month','decisioning'])['amt_usd'].sum().unstack(fill_value=0)
    kpi['Total'] = kpi.sum(axis=1)
    return kpi.div(kpi['Total'], axis=0).mul(100).round(2)

# ── CP vs CNP ────────────────────────────────────────────────────────────────
def cp_cnp_kpi(df):
    g = df.groupby(['month','CP_CNP'])['txns'].sum().unstack(fill_value=0)
    g['Total'] = g.sum(axis=1)
    return g.div(g['Total'], axis=0).mul(100).round(2)

def cp_cnp_kpi_usd(df):
    g = df.groupby(['month','CP_CNP'])['amt_usd'].sum().unstack(fill_value=0)
    g['Total'] = g.sum(axis=1)
    return g.div(g['Total'], axis=0).mul(100).round(2)

