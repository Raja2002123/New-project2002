# ── helpers ────────────────────────────────────────────────────────────
def _cols(df, cmap):
    return [c for c in cmap if c in df.columns]

def _pct(df):
    df = df.fillna(0)
    return df.div(df.sum(axis=1), axis=0).mul(100).round(4)

def _page(pdf, fig, hspace=0.62, wspace=0.28):
    plt.subplots_adjust(left=0.04, right=0.96, top=0.94,
                        bottom=0.05, hspace=hspace, wspace=wspace)
    pdf.savefig(fig, bbox_inches="tight")
    plt.close(fig)

def _title(fig, text):
    fig.suptitle(text, fontsize=13, fontweight="bold", y=0.998,
                 bbox=dict(boxstyle="round,pad=0.3",
                           facecolor="#1C2B4A", alpha=0.92),
                 color="white")

# ════════════════════════════════════════════════════════════════════════
# 1. LOAD DATA
# ════════════════════════════════════════════════════════════════════════
def load_data(path, sheet="Auth Decline Summary"):
    df = pd.read_excel(path, sheet_name=sheet)
    df.columns = df.columns.str.strip().str.lower()
    rename = {c: c for c in df.columns}
    for c in df.columns:
        if c == "cp_cnp":      rename[c] = "CP_CNP"
        elif c == "amt_usd":   rename[c] = "amt_usd"
    df.rename(columns=rename, inplace=True)
    df["month"] = pd.to_datetime(df["month"], format="%b-%y", errors="coerce")
    bad = df["month"].isna()
    if bad.any():
        df.loc[bad, "month"] = pd.to_datetime(df.loc[bad, "month"], errors="coerce")
    df = df.dropna(subset=["month"])
    df = df[df["month"].dt.year == 2025].sort_values("month")
    return df

# ════════════════════════════════════════════════════════════════════════
# 2. KPI FUNCTIONS
# ════════════════════════════════════════════════════════════════════════
def _dec(df):
    return df[df["decisioning"].str.contains("declined", case=False, na=False)]

def _remap_crd(df):
    d = df.copy()
    CRD = ["Insuff_Decline", "Cash_Line", "Credit_Line"]
    d["type"] = d["type"].mask(d["type"].isin(CRD), "Credit Related Decline")
    return d

def _wf(df):
    pat = "STIP_DECLINE|_Other declines|FALCON_DECLINE|Credit Related Decline"
    return df[df["type"].str.contains(pat, case=False, na=False)]

# overall
def kpi_overall(df):
    g = df.groupby(["month", "decisioning"])
    vol     = g["txns"].sum().unstack(fill_value=0)
    vol_usd = g["amt_usd"].sum().unstack(fill_value=0)
    return vol, vol_usd, _pct(vol), _pct(vol_usd)

# decline type waterfall
def kpi_decline_type(df):
    d   = _wf(_remap_crd(_dec(df)))
    piv = d.groupby(["month","type"])["txns"].sum().unstack(fill_value=0)
    usd = d.groupby(["month","type"])["amt_usd"].sum().unstack(fill_value=0)
    tot = df.groupby("month")["txns"].sum()
    tot_u = df.groupby("month")["amt_usd"].sum()
    return (piv, usd,
            piv.div(tot, axis=0).mul(100).round(4),
            usd.div(tot_u, axis=0).mul(100).round(4),
            _pct(piv), _pct(usd))

# CRD
def kpi_crd(df):
    d = _dec(df)
    c = d[d["type"].isin(["Insuff_Decline","Cash_Line","Credit_Line"])]
    pt = c.groupby(["month","type"])["txns"].sum().unstack(fill_value=0)
    pu = c.groupby(["month","type"])["amt_usd"].sum().unstack(fill_value=0)
    tt = df.groupby("month")["txns"].sum()
    tu = df.groupby("month")["amt_usd"].sum()
    crd_t = c.groupby("month")["txns"].sum()
    crd_u = c.groupby("month")["amt_usd"].sum()
    return (_pct(pt), _pct(pu),
            pt.div(tt,axis=0).mul(100).round(4),
            pu.div(tu,axis=0).mul(100).round(4),
            (crd_t/tt*100).round(4), (crd_u/tu*100).round(4),
            (crd_t/_dec(df).groupby("month")["txns"].sum()*100).round(4),
            (crd_u/_dec(df).groupby("month")["amt_usd"].sum()*100).round(4))

# card type
_EXCL = ["TITANIUM","TITANIUM2","WORLD"]
def kpi_card_type(df):
    d   = df[~df["cardtype"].isin(_EXCL)]
    g   = d.groupby(["month","cardtype"])
    gd  = _dec(d).groupby(["month","cardtype"])
    vol = g["txns"].sum().unstack(fill_value=0)
    vu  = g["amt_usd"].sum().unstack(fill_value=0)
    dv  = gd["txns"].sum().unstack(fill_value=0)
    du  = gd["amt_usd"].sum().unstack(fill_value=0)
    return (_pct(vol), _pct(vu), vol, vu,
            dv.div(vol).mul(100).round(4),
            du.div(vu).mul(100).round(4))

# per-card decline reason
def kpi_card_reason(df, card):
    d   = _wf(_remap_crd(_dec(df)))
    d   = d[d["cardtype"] == card]
    piv = d.groupby(["month","type"])["txns"].sum().unstack(fill_value=0)
    pu  = d.groupby(["month","type"])["amt_usd"].sum().unstack(fill_value=0)
    tt  = df[df["cardtype"]==card].groupby("month")["txns"].sum()
    tu  = df[df["cardtype"]==card].groupby("month")["amt_usd"].sum()
    return (piv.div(tt,axis=0).mul(100).round(4), piv,
            pu.div(tu,axis=0).mul(100).round(4),  pu)

# STIP
def kpi_stip(df):
    d  = _dec(df)
    g  = d.groupby(["month","tag"])
    vt = g["txns"].sum().unstack(fill_value=0)
    vu = g["amt_usd"].sum().unstack(fill_value=0)
    tt = df.groupby("month")["txns"].sum()
    tu = df.groupby("month")["amt_usd"].sum()
    return (_pct(vt), _pct(vu), vt, vu,
            vt.div(tt,axis=0).mul(100).round(4),
            vu.div(tu,axis=0).mul(100).round(4))

# CP / CNP
def kpi_cp_cnp(df):
    g  = df.groupby(["month","CP_CNP"])
    gd = _dec(df).groupby(["month","CP_CNP"])
    vt = g["txns"].sum().unstack(fill_value=0)
    vu = g["amt_usd"].sum().unstack(fill_value=0)
    dv = gd["txns"].sum().unstack(fill_value=0)
    du = gd["amt_usd"].sum().unstack(fill_value=0)
    return (_pct(vt), _pct(vu), vt, vu,
            dv.div(vt).mul(100).round(4),
            du.div(vu).mul(100).round(4))

def kpi_cp_wf(df, side):
    d   = _wf(_remap_crd(_dec(df)))
    d   = d[d["CP_CNP"] == side]
    piv = d.groupby(["month","type"])["txns"].sum().unstack(fill_value=0)
    pu  = d.groupby(["month","type"])["amt_usd"].sum().unstack(fill_value=0)
    return _pct(piv), piv, _pct(pu), pu

# other declines granular
def kpi_other(df):
    d   = _dec(df)
    oth = d[d["type"].isin(OTHER_TYPES)]
    pt  = oth.groupby(["month","type"])["txns"].sum().unstack(fill_value=0)
    pu  = oth.groupby(["month","type"])["amt_usd"].sum().unstack(fill_value=0)
    tt  = df.groupby("month")["txns"].sum()
    tu  = df.groupby("month")["amt_usd"].sum()
    dt  = d.groupby("month")["txns"].sum()
    du  = d.groupby("month")["amt_usd"].sum()
    return (pt.div(tt,axis=0).mul(100).round(4),
            pu.div(tu,axis=0).mul(100).round(4),
            pt.div(dt,axis=0).mul(100).round(4),
            pu.div(du,axis=0).mul(100).round(4),
            pt, pu)

