        _, ax = plt.subplots(figsize=(14, 7))
    df  = df_plot.copy().fillna(0)
    lbl = _month_labels(df.index)
    cl  = _cl(df, colors)
    x   = np.arange(len(lbl))
    for i, col in enumerate(df.columns):
        v = df[col].values.astype(float)
        ax.plot(x, v, marker="o", color=cl[i], linewidth=1.8, markersize=5, label=col)
        for xi, vi in enumerate(v):
            ax.annotate(f"{vi:.2f}%" if percent else _fmt_num(vi),
                        (xi, vi), textcoords="offset points", xytext=(0, 7),
                        ha="center", fontsize=6, color=cl[i])
    ax.set_xticks(x)
    ax.set_xticklabels(lbl, rotation=45, ha="right", fontsize=8)
    ax.set_title(title, fontsize=10, fontweight="bold", pad=6)
    ax.set_xlabel("Month", fontsize=8)
    ax.set_ylabel(ylabel, fontsize=8)
    ax.margins(x=0.05)
    if percent:
        ax.yaxis.set_major_formatter(mticker.PercentFormatter())
    ax.legend(loc="upper center", bbox_to_anchor=(0.5, -0.30),
              ncol=min(len(df.columns), 4), frameon=False, fontsize=7.5)
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)
    return ax

