        colLabels = col_labels,
        loc       = "center",
        cellLoc   = "center",
        bbox      = [0.0, 0.0, 1.0, 1.0],
    )
    tbl.auto_set_font_size(False)
    tbl.set_fontsize(fontsize)

    row_h = max(4.0, 18.0 / (n_rows + 1))
    tbl.scale(1.4, row_h)

    BORDER = "#AAAAAA"
    BG     = "#FFFFFF"
    FG     = "#000000"

    # ── Header row ────────────────────────────────────────────────────────
    for j in range(n_cols):
        c = tbl[0, j]
        c.set_facecolor(BG)
        c.set_edgecolor(BORDER)
        c.set_text_props(color=FG, fontweight="bold")

    # ── Row label column ──────────────────────────────────────────────────
    for i in range(1, n_rows + 1):
        c = tbl[i, -1]
        c.set_facecolor(BG)
        c.set_edgecolor(BORDER)
        c.set_text_props(color=FG, fontweight="bold")

