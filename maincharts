# DUAL-AXIS: STACKED BAR + LINE
# =============================================================================
def plot_stacked_bar_with_line(df_bar, series_line, title, ylabel,
                               colors=None, line_color=RED,
                               line_label="Decline Rate %", ax=None):
    if ax is None:
        _, ax = plt.subplots(figsize=(14, 7))
    df  = df_bar.copy().fillna(0)
    lbl = _month_labels(df.index)
    cl  = _cl(df, colors)
    x   = np.arange(len(lbl))
    bot = np.zeros(len(lbl))
    for i, col in enumerate(df.columns):
        v = df[col].values.astype(float)
        ax.bar(x, v, 0.6, bottom=bot, color=cl[i], label=col)
        bot += v
    ax.set_xlabel("Month", fontsize=8)
    ax.set_ylabel(ylabel, fontsize=8)
    ax.set_xticks(x)
    ax.set_xticklabels(lbl, rotation=45, ha="right", fontsize=8)
    ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda v, _: _fmt_num(v)))
    ax2 = ax.twinx()
    lv  = series_line.reindex(df_bar.index).fillna(0).values.astype(float)
    ax2.plot(x, lv, color=line_color, marker="o", linewidth=2, markersize=5, label=line_label)
    for xi, vi in enumerate(lv):
        ax2.annotate(f"{vi:.2f}%", (xi, vi), textcoords="offset points",
                     xytext=(0, 7), ha="center", fontsize=6.5, color=line_color)
    ax2.set_ylabel("Decline Rate %", fontsize=8, color=line_color)
    ax2.yaxis.set_major_formatter(mticker.PercentFormatter())
    ax2.spines["top"].set_visible(False)
    h1, l1 = ax.get_legend_handles_labels()
    h2, l2 = ax2.get_legend_handles_labels()
    ax.legend(h1+h2, l1+l2, loc="upper center", bbox_to_anchor=(0.5, -0.28),
              ncol=min(len(df.columns)+1, 5), frameon=False, fontsize=7.5)
    ax.set_title(title, fontsize=10, fontweight="bold", pad=6)
    ax.spines["top"].set_visible(False)
    return ax

def plot_dual_axis_bar_line(df_bar, series_line, title, ylabel, colors=None, ax=None):
    return plot_stacked_bar_with_line(df_bar, series_line, title, ylabel,
                                      colors=colors, ax=ax)
