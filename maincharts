GREEN  = "#38D200"; RED    = "#D50000"; TEAL   = "#0473EA"
BLUE   = "#52DAFF"; ORANGE = "#F98764"; NAVY   = "#020B43"
LIME   = "#05561C"; GOLD   = "#FFC120"; PINK   = "#82F028"
GREY   = "#525355"
TYPE_COLORS = {
    "Credit Related Decline": BLUE,
    "FALCON_DECLINE":         NAVY,
    "_Other declines":        ORANGE,
    "STIP_DECLINE":           PINK,
}
CRD_COLORS = {
    "Insuff_Decline": TEAL,
    "Credit_Line":    BLUE,
